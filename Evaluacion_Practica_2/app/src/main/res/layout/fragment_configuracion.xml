<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Mi cuenta" android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="16dp" android:textColor="?attr/colorOnSurface"/>

        <TextView android:id="@+id/tv_config_nombre" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="15sp"
            android:textColor="?attr/colorOnSurface" android:layout_marginBottom="4dp"/>

        <TextView android:id="@+id/tv_config_usuario" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="15sp"
            android:textColor="?attr/colorOnSurface" android:layout_marginBottom="4dp"/>

        <TextView android:id="@+id/tv_config_rol" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="15sp"
            android:textColor="?attr/colorOnSurface" android:layout_marginBottom="24dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?attr/colorOutline" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Apariencia" android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="12dp" android:textColor="?attr/colorOnSurface"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="32dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Modo oscuro"
                android:textSize="15sp" android:textColor="?attr/colorOnSurface"/>
            <Switch android:id="@+id/switch_tema"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/layout_admin_usuarios"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="32dp">

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="?attr/colorOutline" android:layout_marginBottom="24dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Usuarios del sistema" android:textSize="16sp" android:textStyle="bold"
                android:layout_marginBottom="12dp" android:textColor="?attr/colorOnSurface"/>

            <Button android:id="@+id/btn_nuevo_usuario"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Nuevo usuario"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_usuarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>

        <Button android:id="@+id/btn_cerrar_sesion"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Cerrar sesión"
            android:backgroundTint="#E53935"/>
    </LinearLayout>
</ScrollView>
