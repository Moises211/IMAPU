<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B132B"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_deta_cliente_nombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre Completo"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TELÉFONO"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_det_cliente_telefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMAIL"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_det_cliente_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIRECCIÓN"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_det_cliente_direccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MUNICIPIO"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_det_cliente_municipio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOTAS"
        android:textColor="#8B949E"
        android:textSize="12sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tv_det_cliente_notas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_det_cliente_llamar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:backgroundTint="#2F80ED"
            android:text=" Llamar"
            android:textColor="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            app:cornerRadius="24dp" />

        <Button
            android:id="@+id/btn_det_cliente_whatsapp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:backgroundTint="#27AE60"
            android:text=" WhatsApp"
            android:textColor="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            app:cornerRadius="24dp" />
    </LinearLayout>

</LinearLayout>