<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText android:id="@+id/et_nombre_prod" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Nombre del producto"
        android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_categoria" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Categoría (ej: Bebidas, Lácteos)"
        android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_precio" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Precio (Q)"
        android:inputType="numberDecimal" android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_stock" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Stock (unidades)"
        android:inputType="number" android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_codigo_barras" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Código de barras (opcional)"
        android:inputType="number"/>
</LinearLayout>
