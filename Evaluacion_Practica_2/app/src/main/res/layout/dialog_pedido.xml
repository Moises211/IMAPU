<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Cliente:" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/sp_cliente_ped" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Producto:" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/sp_producto_ped" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/tv_precio_stock_ped"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="$ 0.00 · Stock disponible: 0"
        android:textStyle="bold" android:layout_marginBottom="8dp"/>

    <EditText android:id="@+id/et_cantidad_ped" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Cantidad"
        android:inputType="number" android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btn_agregar_producto_ped"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Agregar producto"
        android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/tv_detalle_productos_ped"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Sin productos agregados"
        android:minLines="3" android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_total_ped" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Total ($)"
        android:enabled="false" android:layout_marginBottom="12dp"/>

    <EditText android:id="@+id/et_descripcion_ped" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Nota de venta (opcional)"
        android:minLines="2" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Estado:" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/sp_estado_ped" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Método de pago:" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/sp_metodo_pago" android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
